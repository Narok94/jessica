rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUidData() {
      return get(/databases/$(database)/documents/uids/$(request.auth.uid)).data;
    }

    function isOwner(username) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/uids/$(request.auth.uid)) &&
             getUidData().username == username;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/uids/$(request.auth.uid)) && 
         getUidData().role == 'teacher') ||
        (request.auth.token.email == "hollyood.caribe@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /uids/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid && 
                   request.resource.data.keys().hasAll(['username', 'role']) &&
                   request.resource.data.username is string &&
                   request.resource.data.role in ['student', 'teacher'];
      allow update: if isAuthenticated() && request.auth.uid == uid && 
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'role']);
    }

    match /users/{username} {
      allow read: if isAuthenticated() && (isOwner(username) || isAdmin());
      allow create, update: if isAuthenticated() && (isOwner(username) || isAdmin());
      allow delete: if isAdmin();
    }

    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /workouts/{workoutId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // Legacy support or fallback
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}

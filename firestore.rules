rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: exercise_gifs
    // Document ID: normalized exercise name
    // Fields:
    //   - url: string (required, uri)
    //   - updatedAt: string (required, date-time)
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - username: string
    //   - name: string
    //   - role: string (student, teacher)
    //   - streak: number
    //   - totalWorkouts: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/uids/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/uids/$(request.auth.uid)).data.role == 'teacher' || 
           get(/databases/$(database)/documents/uids/$(request.auth.uid)).data.role == 'admin')) ||
         request.auth.token.email == "hollyood.caribe@gmail.com");
    }
    
    function isUserOwner(username) {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/uids/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/uids/$(request.auth.uid)).data.username == username) ||
         request.auth.token.email == "hollyood.caribe@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidGif(data) {
      return hasOnlyAllowedFields(['url', 'updatedAt']) &&
             data.url is string && data.url.size() < 1000 &&
             data.updatedAt is string;
    }

    function isValidUser(data) {
      // Allow all fields since the user object is complex and evolves
      return data.username is string && data.username.size() < 50 &&
             data.name is string && data.name.size() < 100 &&
             data.role in ['student', 'teacher'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /uids/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /exercise_gifs/{exerciseId} {
      allow read: if true; // Publicly readable so all users see GIFs
      allow write: if isAdmin() && isValidGif(request.resource.data);
    }

    match /users/{username} {
      allow read: if isUserOwner(username) || isAdmin();
      allow create: if (isUserOwner(username) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if (isUserOwner(username) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
